{
  "name": "blog-platform",
  "version": "1.0.0",
  "description": "REST API blog platform with Node.js, Express, and MongoDB",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --detectOpenHandles",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/ server.js",
    "lint:fix": "eslint src/ tests/ server.js --fix",
    "format": "prettier --write \"src/**/*.js\" \"tests/**/*.js\" server.js",
    "format:check": "prettier --check \"src/**/*.js\" \"tests/**/*.js\" server.js"
  },
  "keywords": ["blog", "express", "mongodb", "rest-api"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^7.0.0",
    "dotenv": "^16.0.3"
  },
  "devDependencies": {
    "jest": "^29.5.0",
    "supertest": "^6.3.3",
    "nodemon": "^2.0.20",
    "eslint": "^8.40.0",
    "prettier": "^2.8.8",
    "mongodb-memory-server": "^8.12.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testPathIgnorePatterns": ["/node_modules/"]
  }
}
